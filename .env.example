# Bharat Bricks - Local Environment Configuration
# Copy this file to .env and update values as needed

# Application Settings
APP_ENV=local
APP_HOST=127.0.0.1
APP_PORT=8000
DEBUG=true

# Database Configuration
DATABASE_URL=sqlite:///data/complaints.db
# For PostgreSQL (if you want to use it instead of SQLite):
# DATABASE_URL=postgresql://user:password@localhost:5432/bharat_bricks

# Government Body Configuration
BODY_NAME=Madhya Pradesh State Governing Body
BODY_ID=GB001
TREASURY_EMAIL=treasury@mp.gov.in

# Logging
LOG_LEVEL=INFO

# Optional: API Keys (if integrating real services)
# OPENAI_API_KEY=your_key_here
# GOOGLE_MAPS_API_KEY=your_key_here

# Security (for production)
# SECRET_KEY=your_secret_key_here
# JWT_SECRET=your_jwt_secret_here
